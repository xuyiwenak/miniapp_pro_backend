{
  "name": "donkjs",
  "version": "0.1.0",
  "main": "index.js",
  "scripts": {
    "proto": "tsrpc-cli proto",
    "build": "tsrpc-cli build && npm run copy-config && npm run doc",
    "doc": "tsrpc-cli doc",
    "copy-config": "copyfiles -u 1 \"src/apps/begreat/sysconfig/**/*.json\" dist/ && copyfiles -u 1 \"src/apps/mandis/sysconfig/**/*.json\" dist/",
    "dev:begreat": "ts-node src/apps/begreat/front.ts",
    "dev:mandis": "ts-node src/apps/mandis/front.ts",
    "json-to-schemas-development": "node json_to_schema.mjs development",
    "json-to-schemas-production": "node json_to_schema.mjs production",
    "test": "TS_NODE_PROJECT=tsconfig.test.json mocha --require ts-node/register \"test/**/*.test.ts\"",
    "lint": "eslint \"src/**/*.ts\" --max-warnings 0",
    "typecheck": "tsc --noEmit",
    "prepare": "husky"
  },
  "lint-staged": {
    "src/**/*.ts": [
      "eslint --max-warnings 0 --fix"
    ]
  },
  "devDependencies": {
    "@types/bull": "^4.10.4",
    "@types/express": "^4.17.21",
    "@types/mocha": "^10.0.10",
    "@types/multer": "^2.1.0",
    "@types/sinon": "^21.0.0",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.5.10",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "copyfiles": "^2.4.1",
    "eslint": "^8.57.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "mocha": "^11.7.5",
    "sinon": "^21.0.1",
    "ts-node": "^10.9.2",
    "tsrpc-cli": "^2.4.5",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "bcrypt": "^6.0.0",
    "bull": "^4.16.5",
    "cos-nodejs-sdk-v5": "^2.14.7",
    "cron": "^3.1.7",
    "express": "^4.21.2",
    "ioredis": "^5.10.0",
    "json-to-zod": "^1.1.2",
    "jsonwebtoken": "^9.0.3",
    "log4js": "^6.9.1",
    "mongoose": "^8.7.2",
    "multer": "^1.4.5-lts.1",
    "pm2": "^5.4.3",
    "radash": "^12.1.0",
    "rxjs": "^7.8.1",
    "swagger-ui-express": "^5.0.1",
    "tsrpc": "^3.4.21",
    "ws": "^8.18.0",
    "xlsx": "^0.18.5",
    "zod": "^3.23.8",
    "zod-to-ts": "^1.2.0"
  }
}
