{
  "appenders": {
    "server": {
      "filename": "../logs/server.log",
      "type": "dateFile",
      "numBackups": 7,
      "encoding": "utf8",
      "layout": {
        "type": "pattern",
        "pattern": "[%d{yyyy-MM-dd hh:mm:ss.SSS O}] [%p] [%f:%l] -- %m"
      },
      "pattern": "yyyy-MM-dd",
      "keepFileExt": true,
      "alwaysIncludePattern": true
    },
    "game": {
      "filename": "../logs/game.log",
      "type": "dateFile",
      "numBackups": 7,
      "encoding": "utf8",
      "layout": {
        "type": "pattern",
        "pattern": "[%d{yyyy-MM-dd hh:mm:ss.SSS O}] [%p] [%f:%l] -- %m"
      },
      "pattern": "yyyy-MM-dd",
      "keepFileExt": true,
      "alwaysIncludePattern": true
    },
    "console": {
      "type": "console",
      "layout": {
        "type": "pattern",
        "pattern": "%[ [%d{yyyy-MM-dd hh:mm:ss.SSS O}] [%p] [%f:%l] %] -- %m"
      }
    },
    "coze_debug": {
      "filename": "../logs/coze_debug.log",
      "type": "dateFile",
      "numBackups": 7,
      "encoding": "utf8",
      "layout": {
        "type": "pattern",
        "pattern": "[%d{yyyy-MM-dd hh:mm:ss.SSS O}] [%p] -- %m"
      },
      "pattern": "yyyy-MM-dd",
      "keepFileExt": true,
      "alwaysIncludePattern": true
    },
    "prop_history_csv": {
      "filename": "../logs/prop_history.csv",
      "type": "src/util/LoggerCsvDateRollingAppender",
      "numBackups": 7,
      "encoding": "utf8",
      "layout": {
        "type": "messagePassThrough"
      },
      "header": [
        "date",
        "changeData",
        "nowData",
        "beforeData",
        "source"
      ],
      "pattern": "yyyy-MM-dd",
      "keepFileExt": true,
      "alwaysIncludePattern": true
    },
    "payment": {
      "filename": "../logs/payment.log",
      "type": "dateFile",
      "numBackups": 30,
      "encoding": "utf8",
      "layout": {
        "type": "pattern",
        "pattern": "[%d{yyyy-MM-dd hh:mm:ss.SSS O}] [%p] -- %m"
      },
      "pattern": "yyyy-MM-dd",
      "keepFileExt": true,
      "alwaysIncludePattern": true
    }
  },
  "categories": {
    "default": {
      "appenders": [
        "game"
      ],
      "enableCallStack": true,
      "level": "debug"
    },
    "server": {
      "appenders": [
        "server",
        "console"
      ],
      "enableCallStack": true,
      "level": "debug"
    },
    "game": {
      "appenders": [
        "game",
        "console"
      ],
      "enableCallStack": true,
      "level": "debug"
    },
    "prop_history_csv": {
      "appenders": [
        "prop_history_csv",
        "console"
      ],
      "enableCallStack": true,
      "level": "debug"
    },
    "coze_debug": {
      "appenders": [
        "coze_debug",
        "console"
      ],
      "enableCallStack": false,
      "level": "debug"
    },
    "payment": {
      "appenders": [
        "payment",
        "console"
      ],
      "enableCallStack": true,
      "level": "debug"
    }
  }
}