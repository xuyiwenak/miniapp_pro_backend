{
  "internal_server_token": "CHANGE_ME_INTERNAL_TOKEN",
  "account_server_token": "CHANGE_ME_ACCOUNT_TOKEN",
  "wx_miniapp": {
    "appId": "YOUR_WECHAT_APPID",
    "appSecret": "YOUR_WECHAT_APPSECRET"
  },

  "_comment_contentSecurity": "true=启用微信内容安全审核(文字+图片) | false=关闭(本地调试时可关)",
