{
  "appenders": {
    "server": {
      "filename": "logs/server.log",
      "type": "dateFile",
      "numBackups": 7,
      "encoding": "utf8",
      "layout": {
        "type": "pattern",
        "pattern": "[%d{yyyy-MM-dd hh:mm:ss.SSS O}] [%p] [%f:%l] -- %m"
      },
      "pattern": "yyyy-MM-dd",
      "keepFileExt": true,
      "alwaysIncludePattern": true
    },
    "game": {
      "filename": "logs/game.log",
      "type": "dateFile",
      "numBackups": 7,
      "encoding": "utf8",
      "layout": {
        "type": "pattern",
        "pattern": "[%d{yyyy-MM-dd hh:mm:ss.SSS O}] [%p] [%f:%l] -- %m"
      },
      "pattern": "yyyy-MM-dd",
      "keepFileExt": true,
      "alwaysIncludePattern": true
    },
    "console": {
      "type": "console",
      "layout": {
        "type": "pattern",
        "pattern": "%[ [%d{yyyy-MM-dd hh:mm:ss.SSS O}] [%p] [%f:%l] %] -- %m"
      }
    },
    "report_debug": {
      "filename": "logs/report_debug.log",
      "type": "dateFile",
      "numBackups": 7,
      "encoding": "utf8",
      "layout": {
        "type": "pattern",
        "pattern": "[%d{yyyy-MM-dd hh:mm:ss.SSS O}] [%p] -- %m"
      },
      "pattern": "yyyy-MM-dd",
      "keepFileExt": true,
      "alwaysIncludePattern": true
    }
  },
  "categories": {
    "default": {
      "appenders": ["game"],
      "enableCallStack": true,
      "level": "debug"
    },
    "server": {
      "appenders": ["server", "console"],
      "enableCallStack": true,
      "level": "debug"
    },
    "game": {
      "appenders": ["game", "console"],
      "enableCallStack": true,
      "level": "debug"
    },
    "report_debug": {
      "appenders": ["report_debug", "console"],
      "enableCallStack": false,
      "level": "debug"
    }
  }
}
