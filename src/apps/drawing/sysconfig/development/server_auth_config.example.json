{
  "internal_server_token": "CHANGE_ME_INTERNAL_TOKEN",
  "account_server_token": "CHANGE_ME_ACCOUNT_TOKEN",
  "wx_miniapp": {
    "appId": "YOUR_WECHAT_APPID",
    "appSecret": "YOUR_WECHAT_APPSECRET"
  },

  "_comment_contentSecurity": "true=启用微信内容安全审核(文字+图片) | false=关闭(本地调试时可关)",
  "contentSecurity": false,

  "_comment_imageStorage": "oss=阿里云OSS(私有) | cos=腾讯云COS(CDN) | local=本地真机测试(图片存本机 static/uploads，需设 publicBaseUrl)",
  "imageStorage": "local",
  "publicBaseUrl": "http://YOUR_SERVER_IP:MINIAPP_PORT",
  "_comment_oss_cdnDomain": "可选，OSS 签名 URL 使用该 CDN/自定义域名；不填则用 bucket.region.aliyuncs.com",
  "oss": {
    "region": "oss-cn-beijing",
    "accessKeyId": "YOUR_OSS_ACCESS_KEY_ID",
    "accessKeySecret": "YOUR_OSS_ACCESS_KEY_SECRET",
    "bucket": "your-oss-bucket",
    "cdnDomain": "https://your-oss-cdn.example.com"
  },
  "cos": {
    "secretId": "YOUR_COS_SECRET_ID",
    "secretKey": "YOUR_COS_SECRET_KEY",
    "bucket": "your-bucket-1250000000",
    "region": "ap-guangzhou",
    "cdnDomain": "https://your-cdn-domain.example.com"
  },
  "coze": {
    "token": "YOUR_COZE_API_TOKEN",
    "workflowId": "YOUR_COZE_WORKFLOW_ID",
    "baseUrl": "https://api.coze.cn",
    "_comment_cozeCallback": "异步工作流完成时 Coze POST 到 callbackPublicUrl+callbackPath；ext 内键名见 extCallbackUrlKey（与开放平台一致）",
    "callbackPublicUrl": "https://YOUR_DOMAIN",
    "callbackPath": "/healing/coze/callback",
    "extCallbackUrlKey": "hook_url",
    "webhookSecret": "OPTIONAL_LONG_RANDOM_QUERY_TOKEN",
    "fallbackPollAfterMs": 0
  }
}

