# 复制为 .env（.gitignore 已忽略）
# 本机开发：使用 development 与 src/sysconfig/development/
environment=development
ENV=development

# Docker / ECS 由 docker-compose 设为 production，无需在本文件重复

# begreat 管理后台 JWT 签名密钥（随机长字符串，生产环境必须修改）
# 生成命令：node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
BEGREAT_ADMIN_JWT_SECRET=your_random_secret_here
